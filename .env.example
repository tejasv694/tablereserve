# Database — PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/restaurant_db"

# Per-restaurant database URL (slug-based, e.g. DATABASE_URL__your_restaurant_slug)
# DATABASE_URL__your_slug="postgresql://user:password@localhost:5432/db_your_slug"

# Encryption key — 32 bytes, base64 encoded
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY="your_encryption_key_here"

# NextAuth
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="your_nextauth_secret_here"
NEXTAUTH_URL="http://localhost:3000"

# n8n webhook base URL (no trailing slash)
N8N_WEBHOOK_BASE_URL="https://your-n8n-instance.com/webhook"

# Resend (email)
RESEND_API_KEY="re_xxxxxxxxxxxx"
EMAIL_FROM="bookings@yourdomain.com"

# Cron security
CRON_SECRET="your_random_cron_secret"
