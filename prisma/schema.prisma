// Restaurant Booking Platform — Prisma Schema
// Copy this file to /prisma/schema.prisma in your project
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL") // For migrations on serverless (Neon)
}

// ─────────────────────────────────────────────
// RESTAURANT (one per database / tenant)
// ─────────────────────────────────────────────
model Restaurant {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique // used in URL: /{slug}/book
  email        String   // owner email — for CSV exports and notifications
  phone        String?
  address      String?
  timezone     String   @default("Europe/Berlin")
  locale       String   @default("de") // de, en, hi
  currency     String   @default("EUR")

  // Operating hours stored as JSON
  // Format: { "monday": { "open": "12:00", "close": "22:00" }, ... }
  operatingHours Json?

  // Booking config
  slotDurationMinutes  Int @default(120) // 2 hours
  bufferMinutes        Int @default(25)  // 25 min turnover buffer
  slotIntervalMinutes  Int @default(30)  // show slots every 30 min
  maxPartySize         Int @default(12)
  advanceBookingDays   Int @default(60)  // how far ahead customers can book

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tables       Table[]
  bookings     Booking[]
  staffMembers StaffMember[]
  shiftConfig  ShiftConfig?
  shiftPlans   ShiftPlan[]
}

// ─────────────────────────────────────────────
// TABLE
// ─────────────────────────────────────────────
model Table {
  id            String     @id @default(cuid())
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId  String

  label         String     // e.g. "Table 4", "Window Seat A"
  capacity      Int        // max number of guests
  minCapacity   Int        @default(1)
  section       String?    // e.g. "Terrace", "Main Hall", "Bar Area"
  isActive      Boolean    @default(true)
  isOnline      Boolean    @default(true) // show on public booking page

  // Optional: position on table map (for visual layout)
  positionX     Int?
  positionY     Int?

  // Waiter assigned to this table (optional)
  waiterName    String?

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  bookings      Booking[]

  @@index([restaurantId])
}

// ─────────────────────────────────────────────
// BOOKING
// ─────────────────────────────────────────────
model Booking {
  id            String        @id @default(cuid())
  restaurant    Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId  String
  table         Table         @relation(fields: [tableId], references: [id])
  tableId       String

  // ⚠️  PII FIELDS — AES-256-GCM encrypted before storing, decrypt on read
  // Store as encrypted base64 strings. Never store plain text.
  customerName  String        // encrypted
  customerEmail String        // encrypted
  customerPhone String?       // encrypted (optional)

  partySize     Int
  specialRequests String?     // NOT encrypted — keep non-PII

  // Time fields — always stored in UTC
  startTime     DateTime      // booking start (UTC)
  endTime       DateTime      // startTime + slotDurationMinutes (UTC)
  availableFrom DateTime      // startTime + slotDurationMinutes + bufferMinutes (UTC)
                              // next booking cannot start before this

  status        BookingStatus @default(CONFIRMED)

  // GDPR consent — mandatory for EU customers
  gdprConsent   Boolean       @default(false)
  consentAt     DateTime?     // when they checked the box

  // Marketing consent — separate from GDPR, optional opt-in
  marketingConsent Boolean    @default(false)

  // Booking source
  source        BookingSource @default(ONLINE)

  // Internal notes (restaurant staff only, not shown to customer)
  staffNotes    String?

  // Soft delete — set before hard delete in cleanup job
  deletedAt     DateTime?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([restaurantId, startTime])
  @@index([tableId, startTime])
  @@index([restaurantId, status])
}

enum BookingStatus {
  CONFIRMED    // Active booking
  SEATED       // Guest has been seated
  CANCELLED    // Cancelled by customer or restaurant
  COMPLETED    // Guest has left
  NO_SHOW      // Guest did not arrive
  PENDING      // Awaiting confirmation (if manual approval enabled)
}

enum BookingSource {
  ONLINE       // Booked via public booking page
  PHONE        // Added manually by staff (phone call)
  WALKIN       // Walk-in added by staff
  THIRD_PARTY  // From external platform (future: Google, OpenTable)
}

// ─────────────────────────────────────────────
// STAFF MEMBER (restaurant employees who can log in)
// ─────────────────────────────────────────────
model StaffMember {
  id            String     @id @default(cuid())
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId  String

  name          String
  email         String     @unique
  passwordHash  String     // bcrypt hash
  role          StaffRole  @default(STAFF)
  department    StaffDepartment @default(FRONT)
  isActive      Boolean    @default(true)

  // Shift management
  phone         String?    // for WhatsApp/SMS notifications
  contractType  ContractType @default(PART_TIME)
  monthlyHoursTarget Int   @default(80) // 80 for part-time, 150 for full-time
  availabilityToken  String? @unique // unique token for availability form link

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  availability  StaffAvailability[]
  assignments   ShiftAssignment[]

  @@index([restaurantId])
}

enum StaffRole {
  OWNER        // Full access including settings and data export
  MANAGER      // Can manage bookings and tables
  STAFF        // Can view and update booking status only
}

enum StaffDepartment {
  KITCHEN      // Kitchen staff
  FRONT        // Front-of-house / serving
  DELIVERY     // Delivery drivers
  MANAGER      // Floor manager
}

enum ContractType {
  FULL_TIME    // ~150 hours/month
  PART_TIME    // ~80 hours/month
  MINI_JOB     // 520 EUR basis (Germany)
}

// ─────────────────────────────────────────────
// SHIFT CONFIG (restaurant-level shift settings)
// ─────────────────────────────────────────────
model ShiftConfig {
  id            String     @id @default(cuid())
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId  String     @unique

  // Minimum staff requirements per day (JSON)
  // Format: { "KITCHEN": 3, "FRONT": 4, "DELIVERY": 2, "MANAGER": 1 }
  minStaffPerRole Json     @default("{\"KITCHEN\": 2, \"FRONT\": 3, \"DELIVERY\": 1, \"MANAGER\": 1}")
  minTotalStaff   Int      @default(7)

  // Shift timing mode
  shiftMode     ShiftMode  @default(CONSTANT)

  // Defined shift slots (JSON array)
  // Format: [{ "name": "Morning", "start": "08:00", "end": "14:00" }, ...]
  shiftSlots    Json       @default("[{\"name\": \"Morning\", \"start\": \"08:00\", \"end\": \"16:00\"}, {\"name\": \"Evening\", \"start\": \"14:00\", \"end\": \"22:00\"}]")

  // Availability collection settings
  availabilityDeadlineDay DayOfWeek @default(WEDNESDAY) // staff must submit by this day
  planReleaseDay          DayOfWeek @default(THURSDAY)   // shift plan released on this day
  planReleaseTime         String    @default("00:05")    // time of release (HH:mm)

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

enum ShiftMode {
  CONSTANT     // Same shift times each week, only days change per staff request
  SHUFFLE      // Staff rotate between different shift times weekly
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

// ─────────────────────────────────────────────
// STAFF AVAILABILITY (weekly submission)
// ─────────────────────────────────────────────
model StaffAvailability {
  id            String      @id @default(cuid())
  staff         StaffMember @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  staffMemberId String

  weekStartDate DateTime    // Monday of the target week (date only, no time)

  // Available days as JSON array: ["MONDAY", "TUESDAY", "FRIDAY"]
  availableDays Json

  // Preferred shift (optional)
  preferredShift String?    // "Morning", "Evening", or "Any"

  notes         String?     // "Can only do morning on Friday"

  submittedAt   DateTime    @default(now()) // for first-come-first-serve priority

  @@unique([staffMemberId, weekStartDate])
  @@index([weekStartDate])
}

// ─────────────────────────────────────────────
// SHIFT PLAN (generated weekly plan)
// ─────────────────────────────────────────────
model ShiftPlan {
  id            String         @id @default(cuid())
  restaurant    Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId  String

  weekStartDate DateTime       // Monday of the week
  status        ShiftPlanStatus @default(DRAFT)

  // If status is SHORTAGE, details of what's missing (JSON)
  // Format: [{ "day": "FRIDAY", "role": "KITCHEN", "needed": 3, "assigned": 1 }]
  shortageDetails Json?

  generatedAt   DateTime       @default(now())
  releasedAt    DateTime?      // when the plan was sent to staff

  assignments   ShiftAssignment[]

  @@unique([restaurantId, weekStartDate])
  @@index([restaurantId, weekStartDate])
}

enum ShiftPlanStatus {
  DRAFT        // Plan generated but not reviewed
  SHORTAGE     // Plan has gaps — owner must resolve
  RELEASED     // Approved and sent to staff
  OVERRIDDEN   // Owner manually modified the plan
}

// ─────────────────────────────────────────────
// SHIFT ASSIGNMENT (individual shift for one person on one day)
// ─────────────────────────────────────────────
model ShiftAssignment {
  id            String      @id @default(cuid())
  shiftPlan     ShiftPlan   @relation(fields: [shiftPlanId], references: [id], onDelete: Cascade)
  shiftPlanId   String
  staff         StaffMember @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  staffMemberId String

  date          DateTime    // the specific day
  shiftName     String      // "Morning", "Evening", etc.
  shiftStart    String      // "08:00"
  shiftEnd      String      // "16:00"
  role          StaffDepartment // KITCHEN, FRONT, DELIVERY, MANAGER
  hours         Float       // calculated hours for this shift

  status        AssignmentStatus @default(SCHEDULED)
  isOverride    Boolean     @default(false) // true if owner manually placed this

  createdAt     DateTime    @default(now())

  @@index([shiftPlanId])
  @@index([staffMemberId])
  @@index([date])
}

enum AssignmentStatus {
  SCHEDULED    // Normal planned shift
  COMPLETED    // Shift was worked
  CANCELLED    // Shift cancelled (e.g. sick leave resolved)
}
